generator client {
  provider      = "prisma-client-js"
  // "native" pour le dev (macOS), debian-openssl-3.0.x pour le runtime Docker (node:22-slim)
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Contenu éditable du site (landing) — une seule entrée, key = "landing".
// value = JSON sérialisé { hero, plans, faq, ... } édité depuis l'admin.
model SiteContent {
  key       String   @id // "landing"
  value     String // JSON
  updatedAt DateTime @updatedAt
}

// Demandes envoyées via le formulaire de contact public.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  handled   Boolean  @default(false) // marqué comme traité par un admin
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Articles de blog (SEO) — gérés depuis l'admin.
model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String? // résumé (meta description + carte)
  content     String // corps en Markdown
  coverImage  String? // URL d'image de couverture
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model User {
  id        String           @id @default(cuid())
  email     String           @unique
  password  String // hash bcrypt
  name      String?
  createdAt DateTime         @default(now())
  role     String  @default("user") // user | admin
  disabled Boolean @default(false) // compte suspendu par un admin

  // --- Offre / abonnement ---
  plan          String    @default("pro") // essentiel | pro | agence
  trialEndsAt   DateTime? // fin de la période d'essai (14 j)
  planUpdatedAt DateTime? // dernière modification du plan

  // --- Abonnement Stripe ---
  stripeCustomerId     String?   @unique // identifiant client Stripe
  stripeSubscriptionId String?   // identifiant de l'abonnement en cours
  subscriptionStatus   String?   // active | trialing | past_due | canceled | ...
  subscriptionInterval String?   // month | year
  currentPeriodEnd     DateTime? // fin de la période payée en cours

  linkedin  LinkedInAccount?
  instagram InstagramAccount?
  drafts    Draft[]
  resetTokens PasswordResetToken[]
  campaigns Campaign[]
  sources   ContentSource[]
  usage     UsageEvent[]
  events    Event[]
  pushSubs  PushSubscription[]

  // --- Profil de rédaction ---
  headline        String? // titre pro, ex : "Consultant SEO @ Acme"
  expertise       String? // "Je suis un(e)..." — pré-rempli dans le générateur
  themes          String? // thématiques favorites, séparées par des virgules
  tone            String? // ton par défaut (Professionnel, Inspirant, ...)
  styleNotes      String? // consignes libres : tutoiement, emojis, longueur de phrases...
  defaultMaxChars Int? // longueur par défaut des posts
  onboardedAt     DateTime? // null = doit passer par l'onboarding en étapes

  // --- Contexte métier & communication (outil de campagne) ---
  website             String? // site internet de la marque (analysé par l'IA pour nourrir le profil)
  companyName         String? // nom de l'entreprise ou de la marque personnelle
  businessDescription String? // activité, produits/services, proposition de valeur
  targetAudience      String? // audience cible sur LinkedIn
  market              String? // marché, concurrence, positionnement
  commGoals           String? // objectifs de communication (CSV)

  // --- Rythme de publication ---
  postsPerWeek      Int? // déduit des jours choisis
  publishDays       String? // jours préférés, CSV "1,3,5" (1 = lundi)
  publishTime       String? // heure de publication "09:00"
  requireValidation Boolean @default(true) // valider les posts de série avant publication
  autoGenerate      Boolean @default(false) // pilote auto : générer chaque semaine les posts des créneaux à venir

  // --- Phyllo : statistiques du profil personnel ---
  phylloUserId    String? // utilisateur Phyllo lié à ce compte
  phylloAccountId String? // compte LinkedIn connecté via Phyllo Connect

  // --- Multi-compte Agence ---
  // Si managedByUserId est renseigné, ce compte est un client géré par une agence.
  // Le client n'a pas de mot de passe utilisable et n'accède jamais à l'outil.
  managedByUserId String?
  managedBy       User?   @relation("AgencyClients", fields: [managedByUserId], references: [id], onDelete: SetNull)
  clients         User[]  @relation("AgencyClients")
}

// Tokens LinkedIn du client (app perso + app pages entreprise)
model LinkedInAccount {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  personToken     String?
  personSub       String?
  personName      String?
  personExpiresAt DateTime?
  orgToken        String?
  orgExpiresAt    DateTime?
  orgUrn          String?   // urn:li:organization:ID de la première page (compat)
  orgName         String?   // nom de la première page (compat)
  orgAccounts     String?   // JSON : [{urn, name}, ...] — toutes les pages admin
}

// Compte Instagram Business/Creator connecté (via Instagram Login)
// igToken = Instagram User Access Token long-lived (~60 j, renouvelable)
model InstagramAccount {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  igUserId    String    // Instagram User ID (renvoyé par l'échange de code)
  igUsername  String?   // @username Instagram
  igName      String?   // nom affiché
  igPicture   String?   // URL de la photo de profil
  pageId      String?   // obsolète (Facebook Login) — nullable depuis Instagram Login
  pageToken   String    // Instagram User Access Token chiffré (AES-256-GCM)
  expiresAt   DateTime? // expiration du long-lived token (~60 j)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Jetons de réinitialisation de mot de passe (hash SHA-256, usage unique, 1 h)
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

// Consommation IA de la plateforme (tokens Claude, images OpenAI)
model UsageEvent {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind         String   @default("claude") // claude | image
  context      String? // post, série, variantes, retouche, campagne, cadrage, sources, image...
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  images       Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

// Source de veille : site/flux RSS en affinité avec le profil du client
model ContentSource {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String // URL du flux RSS (ou de la page si flux découvert)
  title     String
  createdAt DateTime @default(now())

  @@unique([userId, url])
}

// Campagne LinkedIn : un thème + un brief qui contextualisent la génération
model Campaign {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  theme     String // thème principal de la campagne
  objective String? // objectif spécifique (leads, notoriété...)
  context   String? // brief enrichi : réponses aux questions IA + exemple validé
  status    String   @default("active") // active | archivée
  createdAt DateTime @default(now())
  drafts    Draft[]
}

model Draft {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // simple | carrousel | video
  theme     String
  expertise String
  tone      String
  maxChars  Int
  text      String
  extra     String? // JSON (plan carrousel / script vidéo)
  status    String   @default("brouillon") // brouillon | programmé | publié | erreur
  postId    String? // x-restli-id LinkedIn après publication
  createdAt DateTime @default(now())

  // --- Programmation ---
  scheduledAt  DateTime? // date/heure de publication automatique
  publishedAt  DateTime? // date de publication effective
  target       String    @default("person") // "person" ou "urn:li:organization:ID"
  publishError String? // message d'erreur si la publication automatique a échoué
  auto         Boolean   @default(false) // généré par le moteur de campagne

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  eventId String?
  event   Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  inspirationUrl String? // article de veille sur lequel le post s'appuie

  imageUrl    String? // image générée pour le post (/api/images/...)
  imagePrompt String? // prompt utilisé pour générer l'image

  // --- Instagram ---
  igPostId  String? // media ID Instagram après publication
  igStatus  String? // published | error
}

// Événement (salon, forum…) auquel le client participe : sert à générer
// des posts de rappel sur les jours qui encadrent l'événement.
model Event {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String // nom du salon / forum
  location  String? // lieu, ville, n° de stand
  url       String? // lien de l'événement
  imageUrl  String? // image du salon (récupérée depuis le lien)
  details   String? // description récupérée depuis le lien (contexte pour l'IA)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  remindedAt DateTime? // dernière notification jour-J envoyée (évite les doublons)

  drafts Draft[]

  @@index([userId, startDate])
}

// Abonnement Web Push (notifications) d'un appareil du client
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}
