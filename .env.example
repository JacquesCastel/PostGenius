# ============================================================
# PostGenius — variables d'environnement
# Copier vers .env et remplir. NE JAMAIS commiter le .env.
# ============================================================

# --- Base de données (Postgres / Neon) ---
# Créer un projet sur https://neon.tech → copier la "connection string"
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# --- Super admin ---
# Emails (séparés par des virgules) ayant accès à la vue Administration
ADMIN_EMAILS=

# --- Sécurité ---
# Secret de signature des sessions — générer avec : openssl rand -hex 32
AUTH_SECRET=
# Clé de chiffrement des tokens LinkedIn en base — générer avec : openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# --- API Claude (génération des posts) ---
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI (génération des images de posts) ---
# https://platform.openai.com → API Keys (modèle gpt-image-1)
OPENAI_API_KEY=
# Dossier de stockage des images générées (volume Docker en prod)
IMAGE_DIR=

# --- App LinkedIn n°1 : profil personnel ---
# https://www.linkedin.com/developers/apps — produits "Share on LinkedIn"
# + "Sign In with LinkedIn using OpenID Connect"
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Doit être déclarée À L'IDENTIQUE dans l'onglet Auth de l'app
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback
LINKEDIN_SCOPES=openid profile w_member_social
LINKEDIN_VERSION=202604

# --- App LinkedIn n°2 : pages entreprise (Community Management API) ---
LINKEDIN_ORG_CLIENT_ID=
LINKEDIN_ORG_CLIENT_SECRET=
LINKEDIN_ORG_REDIRECT_URI=http://localhost:3000/api/linkedin/callback-org
LINKEDIN_ORG_SCOPES=w_organization_social rw_organization_admin

# --- URL publique de l'app ---
# En prod : https://postgenius.votredomaine.fr (penser à mettre à jour
# les redirect URIs LinkedIn en conséquence)
APP_URL=http://localhost:3000

# --- Email (mot de passe oublié) ---
# Sans SMTP_HOST (dev), le lien de réinitialisation s'affiche dans le terminal
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="PostGenius <no-reply@votredomaine.fr>"

# --- Phyllo (statistiques du profil LinkedIn personnel) ---
# https://dashboard.getphyllo.com → API credentials
PHYLLO_CLIENT_ID=
PHYLLO_SECRET=
# sandbox (tests) | production
PHYLLO_ENV=sandbox

# --- Programmation des posts ---
# Le planificateur intégré (serveur Node persistant) publie chaque minute.
# CRON_SECRET ne sert que si une plateforme serverless appelle /api/cron/publish-due
CRON_SECRET=
DISABLE_LOCAL_SCHEDULER=
